# RiskLab Backend — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API (optional — app works without it, falls back to pre-written responses)
# Get your free key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT Secret — any long random string for signing session tokens
JWT_SECRET=change-this-to-a-long-random-string-in-production
